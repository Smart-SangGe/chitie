# Local CI config (shell format)
# This file is sourced by tests/local_ci.sh

# 1 = do NOT pass host proxy into podman/docker run/build
CONTAINER_DISABLE_PROXY=1
# Number of scenarios to run in parallel
SCENARIO_JOBS=1
# Auto-build derived test image with procps when source image lacks `ps`
AUTO_INSTALL_PROCPS=1

# Container matrix (comma-separated image list)
MATRIX_IMAGES="ubuntu:22.04,debian:12"
RUN_VULN_ENV=1
VULN_IMAGE_NAME="chitie-vuln-env:local"

# Comparison thresholds
MIN_PRECISION=0.95
MIN_RECALL=0.98

# Expected patterns (comma-separated)
REQUIRED_PATTERNS="suid,/etc/passwd,cron,secret_token,db_pass,cap_setuid"

# Scope control for chitie modules:
# system_information,container,cloud,procs_crons_timers_srvcs_sockets,
# network_information,users_information,software_information,
# interesting_perms_files,interesting_files,api_keys_regex
CHITIE_ONLY_MODULES=""

# Extra CLI args
CHITIE_ARGS=""
LINPEAS_ARGS=""
